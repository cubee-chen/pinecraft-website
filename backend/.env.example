# Server
PORT=5000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/WebService?retryWrites=true&w=majority

# Auth and session
ADMIN_TOKEN=replace_with_strong_admin_token
SESSION_SECRET=replace_with_long_random_session_secret
JWT_SECRET=replace_with_long_random_jwt_secret
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret

# Email sender
EMAIL=replace_with_sender_email@example.com
EMAILPASSWORD=replace_with_email_app_password
EMAILSENDER=Pinecraft Notion
